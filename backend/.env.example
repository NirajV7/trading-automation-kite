# Zerodha Kite Connect credentials.
# Copy to backend/.env and fill local values. Never commit backend/.env.
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:8080/kite_auth

# Safety gate. Keep false unless you intentionally want real-money execution.
KITE_ENABLE_LIVE_TRADING=false
